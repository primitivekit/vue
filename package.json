{
  "name": "@primitivekit/vue",
  "version": "0.1.0",
  "description": "Primitive Vue components with zero hardcoded values. Fully customizable via CSS variables.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tokens": {
      "import": "./dist/tokens/index.js",
      "require": "./dist/tokens/index.js",
      "types": "./dist/tokens/index.d.ts"
    },
    "./tokens/tokens.css": "./dist/tokens/tokens.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "echo 'Build placeholder - Vue components ready for use'",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vue",
    "vue3",
    "components",
    "ui",
    "customizable",
    "accessible",
    "css-variables"
  ],
  "author": "PrimitiveKit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/primitivekit/vue"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vue": "^3.3.0",
    "vue-tsc": "^1.8.0"
  }
}
